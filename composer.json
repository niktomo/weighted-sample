{
    "name": "niktomo/weighted-sample",
    "description": "Weighted random sampling for PHP 8.2+. Supports repeatable draws (WeightedPool), destructive draws (DestructivePool), and box-gacha limited inventory (BoxPool) with alias-method O(1) picking and cryptographically secure randomness by default.",
    "keywords": ["weighted", "random", "sample", "gacha", "box-gacha", "lottery", "raffle", "probability", "selection", "alias-method", "walker-alias", "weighted-shuffle", "cryptographically-secure"],
    "homepage": "https://github.com/niktomo/weighted-sample",
    "authors": [
        {
            "name": "niktomo",
            "role": "Developer"
        }
    ],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.0",
        "phpmd/phpmd": "^2.15"
    },
    "autoload": {
        "psr-4": {
            "WeightedSample\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WeightedSample\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --no-coverage",
        "coverage": "vendor/bin/phpunit --coverage-html coverage/",
        "stan": "vendor/bin/phpstan analyse --memory-limit=512M",
        "pint": "vendor/bin/pint",
        "phpmd": "php -d error_reporting=24575 vendor/bin/phpmd src/ text phpmd.xml"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
